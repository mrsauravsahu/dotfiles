#!/bin/bash

# --- Configuration ---
API_URL="${GENAI_BASE_URL:-http://localhost:9000}/v1/chat/completions"
# Target size for scaling (e.g., 1024px on the longest side). 
TARGET_SIZE="1024"
# Standardized output format for the API (PNG)
OUTPUT_FORMAT="png"


# Ensure both temporary files are deleted even if the script fails
trap "rm -f $TEMP_IMAGE_PATH $TEMP_PAYLOAD" EXIT


# --- Input Validation ---

# Argument order: $1 = Prompt, $2 = Image Path
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 \"<prompt>\" <image_path>"
    echo "Example: $0 \"Describe this image in detail.\" ./my_photo.jpg"
    exit 1
fi

CURRENT_PROMPT="$1"
IMAGE_PATH="$2"

# --- Temporary File Setup ---
# We standardize the temporary image path to force PNG output
TEMP_IMAGE_PATH="${IMAGE_PATH}.scaled.${OUTPUT_FORMAT}"
TEMP_PAYLOAD="${IMAGE_PATH}.payload.txt" 
TEMP_RESPONSE="${IMAGE_PATH}.response.txt" 

# Check if the image file exists
if [ ! -f "$IMAGE_PATH" ]; then
    echo "Error: Image file not found at path: $IMAGE_PATH"
    exit 1
fi

# Check for ImageMagick dependency
if ! command -v convert &> /dev/null; then
    echo "Error: ImageMagick 'convert' utility not found."
    echo "Please install ImageMagick (e.g., sudo apt install imagemagick) to run this script."
    exit 1
fi


# --- Determine Image Type and MIME ---

EXTENSION="${IMAGE_PATH##*.}"
EXTENSION=$(echo "$EXTENSION" | tr '[:upper:]' '[:lower:]')

# IMPORTANT: Since we are converting to PNG, the MIME type for the API call is standardized.
MIME_TYPE="image/png"

case "$EXTENSION" in
    jpg|jpeg)
        echo "-> Detected image type: .$EXTENSION. Converting to $OUTPUT_FORMAT."
        ;;
    png)
        echo "-> Detected image type: .$EXTENSION. Retaining format."
        ;;
    heic)
        echo "-> Detected image type: .$EXTENSION. Converting to $OUTPUT_FORMAT."
        ;;
    *)
        echo "Error: Unsupported image format. Only JPG, JPEG, PNG, and HEIC are supported."
        exit 1
        ;;
esac

# --- Image Scaling and Conversion (TO PNG) ---

echo "-> Scaling image down to max dimension: $TARGET_SIZEpx and converting to PNG..."

# Use ImageMagick to scale the image and explicitly save it as PNG.
# We use -quality 80 for JPEG/lossy formats, but since we are going to PNG (lossless), 
# we focus on the resize and format.
if ! convert "$IMAGE_PATH" -resize "${TARGET_SIZE}x${TARGET_SIZE}>" -define png:compression-level=9 "$TEMP_IMAGE_PATH"; then
    echo "Error: Failed to scale or convert the image using ImageMagick. Check file integrity."
    exit 1
fi

# --- Image Encoding ---

echo "-> Encoding scaled PNG image to Base64..."

# Encode the SCALED PNG image content from the temporary path.
BASE64_IMAGE=$(cat "$TEMP_IMAGE_PATH" | base64)

if [ -z "$BASE64_IMAGE" ]; then
    echo "Error: Failed to encode the image. Check file permissions."
    exit 1
fi

# --- JSON Payload Construction (STANDARD PNG FORMAT) ---

# The MIME type is now fixed to image/png
IMAGE_DATA="data:${MIME_TYPE};base64,${BASE64_IMAGE}"

# Construct the payload as a single OBJECT, as required by the server.
MESSAGES_JSON=$(cat <<EOF
{
  "model": "gemma4-gguf", 
  "messages": [
    {
      "role": "user",
      "content": [
        {
          "type": "text", 
          "text": "${CURRENT_PROMPT}"
        },
        {
          "type": "image_url",
          "image_url": { "url": "${IMAGE_DATA}" }
        }
      ]
    }
  ]
}
EOF
)

echo "-> Payload constructed using standardized PNG data URI."

# --- Writing Payload to Temp File ---
echo "$MESSAGES_JSON" > "$TEMP_PAYLOAD"
echo "-> Payload saved to temporary file."

# --- Synchronous API Call ---

echo ""
echo "==================================================================="
echo "🚀 Sending synchronous request to Llama.cpp server at ${API_URL}..."
echo "==================================================================="

# Use curl to capture the ENTIRE response into a variable (no piping)
RESPONSE=$(curl -s -X POST "$API_URL" \
     -H "Content-Type: application/json" \
     -d @"$TEMP_PAYLOAD")

# --- Output Result ---

echo ""
echo "==================================================================="
echo "✅ Analysis Complete"
echo "==================================================================="

echo "$RESPONSE" > "${TEMP_RESPONSE}"

# Use jq to parse the complete response and extract the text
if command -v jq &> /dev/null; then
    # Extract the text from the completed JSON response
    cat ${TEMP_RESPONSE} | jq -r '.choices[0].message.content'
else
    echo "Warning: 'jq' not found. Printing raw response:"
    echo "$RESPONSE"
fi

exit 0
